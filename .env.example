# Pantheon environment configuration
# Copy this file to .env and fill in all values
# Never commit .env to version control

# Google / Gemini
GEMINI_API=

# Amazon Nova (Bedrock)
AMAZON_NOVA_API=

# Telegram
TELEGRAM_BOT_TOKEN=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_AGENT_ID=

# Sandbox service
SANDBOX_URL=http://localhost:9090

# Vultr / Deployment
VULTR_SERVER_IP=
VULTR_SERVER_USER=root
VULTR_SERVER_PASS=

# Voice call Mini App (requires HTTPS for Telegram WebApps)
WEBAPP_BASE_URL=
WEBAPP_PORT=8443

# Optional: Slack notifications
SLACK_WEBHOOK_URL=

# Application
LOG_LEVEL=INFO
SAMPLES_DIR=/tmp/samples
ENVIRONMENT=production

# Pantheon environment configuration
# Copy this file to .env and fill in all values
# Never commit .env to version control

# Google / Gemini
GEMINI_API=
GOOGLE_API_KEY=

# Amazon Nova (Bedrock)
AMAZON_NOVA_API=

# Telegram
TELEGRAM_BOT_TOKEN=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_AGENT_ID=

# Sandbox service
SANDBOX_URL=http://localhost:9090

# Vultr / Deployment
VULTR_SERVER_IP=
VULTR_SERVER_USER=root
VULTR_SERVER_PASS=

# Voice call Mini App (requires HTTPS for Telegram WebApps)
WEBAPP_BASE_URL=
WEBAPP_PORT=8443

# Google Cloud Run (set after running infra/cloud-deploy.sh)
GCP_PROJECT_ID=
CLOUD_RUN_REGION=us-central1
PANTHEON_AGENTS_URL=
PANTHEON_IMPACT_AGENT_URL=

# ADK A2A wiring (auto-set by cloud-deploy.sh; override for local dev)
PANTHEON_IMPACT_AGENT_CARD_URL=http://localhost:8001/.well-known/agent.json

# Optional: Slack notifications
SLACK_WEBHOOK_URL=

# Application
LOG_LEVEL=INFO
SAMPLES_DIR=/tmp/samples
ENVIRONMENT=production

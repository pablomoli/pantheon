# Pantheon environment configuration
# Copy this file to .env and fill in all values
# Never commit .env to version control

# OpenRouter (all LLM inference — ADK agents + tools + Muse STT fallback)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional — defaults shown in agents/openrouter_client.py / agents/model_config.py
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://github.com/pantheon
OPENROUTER_TITLE=Pantheon
# Optional per-tier model overrides (defaults match former Gemini IDs via OpenRouter):
#   PANTHEON_PRO_MODEL=google/gemini-3.1-pro-preview
#   PANTHEON_FLASH_MODEL=google/gemini-3-flash-preview
#   PANTHEON_LITE_MODEL=google/gemini-3.1-flash-lite-preview
# PANTHEON_PRO_MODEL=
# PANTHEON_FLASH_MODEL=
# PANTHEON_LITE_MODEL=
# PANTHEON_MUSE_STT_MODEL=
# PANTHEON_ANALYST_MODEL=

# Amazon Nova (Bedrock)
AMAZON_NOVA_API=

# Telegram
TELEGRAM_BOT_TOKEN=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_AGENT_ID=

# Hephaestus sandbox + event bus (POST /events, /sandbox/*). Agent tools use this key.
SANDBOX_API_URL=http://localhost:9000
# Legacy name; prefer SANDBOX_API_URL. Some older templates used SANDBOX_URL.
# SANDBOX_URL=http://localhost:9000

# Vultr / Deployment
VULTR_SERVER_IP=
VULTR_SERVER_USER=root
VULTR_SERVER_PASS=

# Voice call Mini App (requires HTTPS for Telegram WebApps)
WEBAPP_BASE_URL=
WEBAPP_PORT=8443

# Google Cloud Run (set after running infra/cloud-deploy.sh)
GCP_PROJECT_ID=
CLOUD_RUN_REGION=us-central1
PANTHEON_AGENTS_URL=
PANTHEON_IMPACT_AGENT_URL=

# ADK A2A wiring (auto-set by cloud-deploy.sh; override for local dev)
PANTHEON_IMPACT_AGENT_CARD_URL=http://localhost:8001/.well-known/agent.json

# Optional: Slack notifications
SLACK_WEBHOOK_URL=

# Application
LOG_LEVEL=INFO
SAMPLES_DIR=/tmp/samples
ENVIRONMENT=production

# Pantheon environment configuration
# Copy this file to .env and fill in all values
# Never commit .env to version control

# Google / Gemini
GEMINI_API=

# Amazon Nova (Bedrock)
AMAZON_NOVA_API=

# Telegram
TELEGRAM_BOT_TOKEN=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Sandbox service (internal Docker network — do not expose publicly)
SANDBOX_API_URL=http://sandbox:9000

# Vultr / Deployment
VULTR_SERVER_IP=
VULTR_SERVER_USER=root
VULTR_SERVER_PASS=

# Optional: Slack notifications
SLACK_WEBHOOK_URL=

# Application
LOG_LEVEL=INFO
SAMPLES_DIR=/tmp/samples
ENVIRONMENT=production
